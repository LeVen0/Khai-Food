# Налаштування надсилання email (коди підтвердження / відновлення пароля).
# Скопіюйте цей файл у server/.env і впишіть свої дані.
# Якщо .env відсутній — працює DEV-режим: код друкується в консоль сервера
# і повертається у відповіді API (поле devCode), реальні листи не надсилаються.

# Приклад для Gmail (потрібен "App Password", а не звичайний пароль акаунта):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=Khai Food <your_email@gmail.com>

# Інші провайдери: вкажіть відповідні host/port/user/pass.

# Секретний ключ для підпису JWT-токенів (обов'язково змініть на власний у продакшні).
JWT_SECRET=change_me_to_a_long_random_secret
